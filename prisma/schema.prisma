generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id            Int       @id @default(autoincrement())
  mobile        String    @unique @db.VarChar(15)
  email         String?   @unique @db.VarChar(255)
  passwordHash  String?   @db.VarChar(255)
  name          String?   @db.VarChar(100)
  isVerified    Boolean   @default(false)
  is2FAEnabled  Boolean   @default(false)
  role          Role      @default(CUSTOMER)
  status        UserStatus @default(PENDING)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  otpRecords    OtpRecord[]
  kycRecord     KycRecord?
  emiAccounts   EmiAccount[]
  sessions      Session[]
  mandates      MandateRecord[]

  @@index([mobile])
}

model MandateRecord {
  id                  Int            @id @default(autoincrement())
  userId              Int
  emiAccountId        Int?
  razorpayCustomerId  String?        @db.VarChar(50)
  razorpayOrderId     String?        @db.VarChar(50)
  razorpayPaymentId   String?        @db.VarChar(50)
  razorpayTokenId     String?        @db.VarChar(50)
  authType            String         @default("netbanking") @db.VarChar(20)
  maxAmount           Decimal        @db.Decimal(12, 2)
  status              MandateStatus  @default(PENDING)
  referenceNo         String?        @unique @db.VarChar(50)
  failureReason       String?        @db.VarChar(255)
  activatedAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  emiAccount          EmiAccount?    @relation(fields: [emiAccountId], references: [id])

  @@index([userId])
  @@index([razorpayTokenId])
}

model OtpRecord {
  id         Int      @id @default(autoincrement())
  userId     Int?
  mobile     String   @db.VarChar(15)
  otp        String   @db.VarChar(6)
  purpose    OtpPurpose
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mobile, purpose])
}

model Session {
  id        String   @id @default(cuid())
  userId    Int
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KycRecord {
  id                Int       @id @default(autoincrement())
  userId            Int       @unique
  aadhaarNumber     String?   @db.VarChar(12)
  aadhaarVerified   Boolean   @default(false)
  panNumber         String?   @db.VarChar(10)
  panDocUrl         String?   @db.VarChar(500)
  selfieUrl         String?   @db.VarChar(500)
  titleDeedUrl      String?   @db.VarChar(500)
  chequeUrl         String?   @db.VarChar(500)
  bankAccount       String?   @db.VarChar(20)
  ifscCode          String?   @db.VarChar(11)
  bankVerified      Boolean   @default(false)
  refContact        String?   @db.VarChar(15)
  fatherContact     String?   @db.VarChar(15)
  motherContact     String?   @db.VarChar(15)
  agreementSigned   Boolean   @default(false)
  agreementUrl      String?   @db.VarChar(500)
  status            KycStatus @default(PENDING)
  rejectionReason   String?   @db.VarChar(500)
  reviewedBy        Int?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmiAccount {
  id              Int           @id @default(autoincrement())
  userId          Int
  loanAmount      Decimal       @db.Decimal(12, 2)
  emiAmount       Decimal       @db.Decimal(10, 2)
  totalEmis       Int
  paidEmis        Int           @default(0)
  nextDueDate     DateTime?
  processingFee   Decimal       @db.Decimal(10, 2) @default(0)
  gstAmount       Decimal       @db.Decimal(10, 2) @default(0)
  mandateId       String?       @db.VarChar(100)
  mandateStatus   MandateStatus @default(PENDING)
  status          EmiStatus     @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments        Payment[]
  mandates        MandateRecord[]

  @@index([userId])
}

model Payment {
  id              Int           @id @default(autoincrement())
  emiAccountId    Int
  razorpayOrderId String?       @db.VarChar(100)
  razorpayPaymentId String?     @db.VarChar(100)
  amount          Decimal       @db.Decimal(10, 2)
  gst             Decimal       @db.Decimal(10, 2) @default(0)
  type            PaymentType
  status          PaymentStatus @default(PENDING)
  receiptUrl      String?       @db.VarChar(500)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  emiAccount      EmiAccount    @relation(fields: [emiAccountId], references: [id], onDelete: Cascade)

  @@index([emiAccountId])
  @@index([razorpayOrderId])
}

enum Role {
  CUSTOMER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum OtpPurpose {
  REGISTRATION
  LOGIN
  PASSWORD_RESET
  TWO_FA
}

enum KycStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum MandateStatus {
  PENDING
  ACTIVE
  FAILED
  CANCELLED
}

enum EmiStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
}

enum PaymentType {
  EMI
  ADVANCE_EMI
  PROCESSING_FEE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}
